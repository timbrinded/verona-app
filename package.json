{
  "name": "verona-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "tsx tests/e2e/smoke.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "mkdir -p data && drizzle-kit migrate",
    "db:seed": "tsx scripts/db/seed.ts",
    "db:export": "tsx scripts/db/export.ts",
    "db:setup": "npm run db:migrate && npm run db:seed && npm run db:export",
    "enrich:preflight": "tsx scripts/enrichment/preflight.ts",
    "enrich:audit": "tsx scripts/enrichment/qa.ts --soft",
    "enrich:qa": "tsx scripts/enrichment/qa.ts",
    "enrich:discover": "tsx scripts/enrichment/discover.ts",
    "enrich:google-candidates": "tsx scripts/enrichment/google-candidates.ts",
    "enrich:late-night-candidates": "tsx scripts/enrichment/late-night-candidates.ts",
    "enrich:prepare": "tsx scripts/enrichment/prepare.ts",
    "enrich:run": "tsx scripts/enrichment/run.ts",
    "enrich:run:late-night": "tsx scripts/enrichment/run-late-night.ts",
    "enrich:cleanup-late-night": "tsx scripts/enrichment/manual-late-night-cleanup.ts",
    "enrich:parallel-json-to-csv": "tsx scripts/enrichment/parallel-json-to-csv.ts",
    "enrich:merge-candidates": "tsx scripts/enrichment/merge-candidates.ts",
    "enrich:merge-late-night": "tsx scripts/enrichment/merge-late-night.ts",
    "enrich:import": "tsx scripts/enrichment/import.ts",
    "enrich:media": "tsx scripts/enrichment/process-media.ts",
    "enrich:promote-seed": "tsx scripts/enrichment/promote-seed.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.17",
    "@serwist/next": "^9.5.11",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.21.0",
    "mapbox-gl": "^3.25.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "playwright": "^1.61.0",
    "serwist": "^9.5.11",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
