# Get a free Mapbox token at https://mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Local development defaults to file:./data/verona.db when unset.
# Production on Vercel should use Turso/libSQL.
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Required only when running manual Parallel enrichment scripts.
PARALLEL_API_KEY=your_parallel_api_key
